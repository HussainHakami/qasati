# Qasati - Dockerfile for Development
# Provides hot-reload for both frontend and backend

FROM node:18-alpine

WORKDIR /app

# Install system dependencies
RUN apk add --no-cache git

# Copy package files first (better caching)
COPY package*.json ./
COPY tsconfig*.json ./
COPY drizzle.config.ts ./
COPY vite.config.ts ./

# Install all dependencies (including devDependencies)
RUN npm install

# Copy environment file
COPY .env ./

# Copy source code
COPY src/ ./src/
COPY api/ ./api/
COPY db/ ./db/
COPY contracts/ ./contracts/
COPY server/ ./server/
COPY public/ ./public/

# Expose ports
# 3000 - Main application port (Vite dev server + API)
# 5173 - Vite HMR (WebSocket)
EXPOSE 3000 5173

# Set development environment
ENV NODE_ENV=development
ENV PORT=3000

# Use Vite's dev server with Hono dev server plugin
# This provides both frontend HMR and backend hot-reload
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
